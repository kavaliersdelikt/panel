{
  "name": "Airlink",
  "version": "2.0.0-beta-rc2",
  "description": "Airlink is a simple-to-use game server management panel",
  "repository": {
    "type": "git",
    "url": "https://github.com/AirlinkLabs/panel"
  },
  "author": "AirlinkLabs",
  "license": "MIT",
  "scripts": {
    "start": "prisma generate && node dist/app.js",
    "prestart": "prisma generate",
    "start:dev": "concurrently \"npm run dev\"",
    "dev": "prisma migrate deploy && prisma generate && nodemon",
    "build": "tsc && tsc -p tsconfig.prisma.json && tailwindcss -i ./public/tw.css -o ./public/styles.css",
    "build:css": "tailwindcss -i ./public/tw.css -o ./public/styles.css --watch",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy && prisma generate",
    "generate": "prisma generate",
    "lint": "eslint src --fix",
    "format": "prettier --write src/",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.prisma.json --noEmit"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.8.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "compression": "^1.8.1",
    "consola": "^3.4.2",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.6.1",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "express-ws": "^5.0.2",
    "form-data": "^4.0.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "monaco-editor": "^0.55.1",
    "multer": "^2.0.2",
    "prisma": "^7.8.0",
    "validator": "^13.12.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@tailwindcss/cli": "^4.1.17",
    "@tailwindcss/forms": "^0.5.11",
    "@types/adm-zip": "^0.5.7",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.1",
    "@types/express-ws": "^3.0.5",
    "@types/hpp": "^0.2.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.8.6",
    "@types/validator": "^13.12.0",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "fallow": "^2.84.0",
    "nodemon": "^3.1.9",
    "oxlint": "^1.67.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.15.0"
  },
  "pnpm": {
    "overrides": {
      "cookie": "^0.7.2",
      "dompurify": "^3.4.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "better-sqlite3"
    ]
  }
}
