<%- include('../../components/header', { title: 'API Keys' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>
  <%- include('../../components/toast') %>

  <div class="px-4 py-5">

    <div class="flex items-start justify-between mb-5">
      <div>
        <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.navApiKeys || 'API Keys' %></h1>
        <p class="text-xs text-neutral-500 mt-0.5">Manage API keys and permissions</p>
      </div>
      <div class="flex gap-2 shrink-0">
        <a href="/admin/api/docs">
          <button type="button" class="inline-flex items-center rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition active:scale-95">Docs</button>
        </a>
        <button id="createApiKeyBtn" type="button" class="inline-flex items-center gap-1.5 rounded-xl bg-neutral-900 dark:bg-neutral-800 border border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-300 hover:bg-neutral-800 dark:hover:bg-neutral-700 transition active:scale-95">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          New Key
        </button>
      </div>
    </div>

    <!-- API key cards -->
    <div class="space-y-2">
      <% if (apiKeys.length === 0) { %>
        <div class="py-16 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-10 h-10 mx-auto mb-3 text-neutral-300 dark:text-neutral-700">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z" />
          </svg>
          <p class="text-sm text-neutral-500">No API keys yet</p>
        </div>
      <% } else { %>
        <% apiKeys.forEach(apiKey => { %>
          <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
            <div class="flex items-start gap-3 mb-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-0.5">
                  <p class="text-sm font-medium text-neutral-800 dark:text-white truncate"><%= apiKey.name %></p>
                  <span class="shrink-0 text-[10px] font-medium px-1.5 py-0.5 rounded-md <%= apiKey.active ? 'bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20' : 'bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-500/20' %>">
                    <%= apiKey.active ? 'Active' : 'Inactive' %>
                  </span>
                </div>
                <% if (apiKey.description) { %>
                  <p class="text-xs text-neutral-500 truncate"><%= apiKey.description %></p>
                <% } %>
              </div>
            </div>

            <div class="flex items-center gap-2 mb-3 bg-neutral-100 dark:bg-neutral-800/50 rounded-lg px-3 py-2">
              <code class="text-xs font-mono text-neutral-600 dark:text-neutral-400 flex-1 truncate"><%= apiKey.key.substring(0, 8) %>...</code>
              <button type="button" onclick="copyToClipboard('<%= apiKey.key %>')" class="shrink-0 text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition active:scale-90" aria-label="Copy API key">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
                </svg>
              </button>
            </div>

            <div class="flex items-center justify-between">
              <p class="text-xs text-neutral-500">By <%= apiKey.user ? apiKey.user.username : 'System' %> · <%= new Date(apiKey.createdAt).toLocaleDateString() %></p>
              <div class="flex gap-1.5">
                <button onclick="showEditModal('<%= apiKey.id %>', '<%= apiKey.name %>', '<%= (apiKey.description || '').replace(/'/g, "\\'") %>', <%= JSON.stringify(apiKey.permissions) %>)" type="button" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 p-1.5 text-neutral-600 dark:text-neutral-400 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition active:scale-90" aria-label="Edit API key">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z" />
                  </svg>
                </button>
                <form action="/admin/apikeys/toggle/<%= apiKey.id %>" method="POST" class="inline">
                  <%- include('../../components/csrf') %>
                  <button type="submit" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 p-1.5 text-neutral-600 dark:text-neutral-400 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition active:scale-90" aria-label="<%= apiKey.active ? 'Disable API key' : 'Enable API key' %>">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                      <% if (apiKey.active) { %>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
                      <% } else { %>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                      <% } %>
                    </svg>
                  </button>
                </form>
                <form id="deleteKeyForm_<%= apiKey.id %>" action="/admin/apikeys/delete/<%= apiKey.id %>" method="POST" class="inline">
                  <%- include('../../components/csrf') %>
                  <button type="button" onclick="confirmDeleteApiKey('<%= apiKey.id %>')" class="rounded-lg bg-red-600 p-1.5 text-white hover:bg-red-500 transition active:scale-90" aria-label="Delete API key">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>

  </div>
</main>

<!-- Create Key Modal -->
<div id="createApiKeyModal" class="fixed inset-0 z-50 hidden items-end justify-center bg-black/60" aria-hidden="true">
  <div class="bg-white dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-700/60 rounded-t-2xl w-full shadow-2xl max-h-[90vh] overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="createApiKeyTitle" aria-describedby="createApiKeyDescription" tabindex="-1">

    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-200 dark:border-neutral-700/60 sticky top-0 bg-white dark:bg-neutral-900 z-10">
      <div>
        <p id="createApiKeyTitle" class="text-sm font-semibold text-neutral-800 dark:text-white">New API Key</p>
        <p id="createApiKeyDescription" class="text-xs text-neutral-500 mt-0.5">Set a name and choose what this key can do.</p>
      </div>
      <button type="button" onclick="hideCreateModal()" class="w-7 h-7 flex items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800 text-neutral-500 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition active:scale-90" aria-label="Close new API key dialog">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <form action="/admin/apikeys/create" method="POST" class="px-5 py-4 space-y-4">
      <%- include('../../components/csrf') %>

      <div class="space-y-3">
        <input type="text" name="name" placeholder="Key name" required
          class="w-full rounded-xl bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500 transition">
        <textarea name="description" placeholder="Description (optional)" rows="2"
          class="w-full rounded-xl bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500 transition resize-none"></textarea>
      </div>

      <div>
        <p class="text-xs font-medium text-neutral-700 dark:text-neutral-300 mb-2">Presets</p>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-preset="full-admin" class="create-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Full Admin</button>
          <button type="button" data-preset="read-only" class="create-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Read-Only</button>
          <button type="button" data-preset="server-manager" class="create-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Server Manager</button>
          <button type="button" data-preset="user-manager" class="create-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">User Manager</button>
          <button type="button" data-preset="node-monitor" class="create-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Node Monitor</button>
          <button type="button" data-preset="none" class="create-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Clear All</button>
        </div>
      </div>

      <div>
        <p class="text-xs font-medium text-neutral-700 dark:text-neutral-300 mb-2">Permissions</p>
        <div class="space-y-2">
          <% ['servers', 'users', 'nodes', 'settings'].forEach(category => { %>
            <div class="rounded-xl border border-neutral-200 dark:border-neutral-700/60 overflow-hidden">
              <button type="button"
                class="w-full flex items-center justify-between px-4 py-3 bg-neutral-50 dark:bg-neutral-800 active:bg-neutral-100 dark:active:bg-neutral-700/60 transition-colors"
                aria-expanded="false"
                onclick="toggleCat(this)">
                <div class="flex items-center gap-2">
                  <span class="text-xs font-medium text-neutral-700 dark:text-neutral-300 capitalize"><%= category %></span>
                  <span class="create-cat-count text-[10px] text-neutral-400 dark:text-neutral-500" data-category="<%= category %>"></span>
                </div>
                <svg class="category-chevron w-3.5 h-3.5 text-neutral-400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </button>
              <div class="category-panel hidden px-3 py-3 bg-white dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-700/60">
                <div class="grid grid-cols-2 gap-2">
                  <% allPermissions.filter(p => p.value.includes(category)).forEach(permission => { %>
                    <label class="create-perm-label flex items-center gap-2 px-3 py-2.5 rounded-lg border border-neutral-100 dark:border-neutral-700/40 bg-neutral-50 dark:bg-neutral-800/50 cursor-pointer active:scale-95 transition-all duration-150">
                      <input type="checkbox" name="permissions" value="<%= permission.value %>"
                        class="permission-checkbox h-3.5 w-3.5 rounded shrink-0" data-category="<%= category %>"
                        onchange="refreshLabels(this, 'create', '<%= category %>')">
                      <span class="perm-text text-xs text-neutral-600 dark:text-neutral-300"><%= permission.name.split(' - ')[1] || permission.name %></span>
                    </label>
                  <% }); %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="flex gap-2 pb-2">
        <button type="button" onclick="hideCreateModal()" class="flex-1 py-2.5 text-xs font-medium rounded-xl border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 active:scale-95 transition"><%= req.translations.cancel || 'Cancel' %></button>
        <button type="submit" class="flex-1 py-2.5 text-xs font-medium rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 active:scale-95 transition"><%= req.translations.create || 'Create' %></button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Key Modal -->
<div id="editApiKeyModal" class="fixed inset-0 z-50 hidden items-end justify-center bg-black/60" aria-hidden="true">
  <div class="bg-white dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-700/60 rounded-t-2xl w-full shadow-2xl max-h-[90vh] overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="editApiKeyTitle" aria-describedby="editApiKeyDescription" tabindex="-1">

    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-200 dark:border-neutral-700/60 sticky top-0 bg-white dark:bg-neutral-900 z-10">
      <div>
        <p id="editApiKeyTitle" class="text-sm font-semibold text-neutral-800 dark:text-white">Edit API Key</p>
        <p id="editApiKeyDescription" class="text-xs text-neutral-500 mt-0.5">Update permissions and details.</p>
      </div>
      <button type="button" onclick="hideEditModal()" class="w-7 h-7 flex items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800 text-neutral-500 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition active:scale-90" aria-label="Close edit API key dialog">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <form id="editApiKeyForm" action="/admin/apikeys/edit/0" method="POST" class="px-5 py-4 space-y-4">
      <%- include('../../components/csrf') %>

      <div class="space-y-3">
        <input type="text" name="name" id="edit-name" placeholder="Key name" required
          class="w-full rounded-xl bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500 transition">
        <textarea name="description" id="edit-description" placeholder="Description (optional)" rows="2"
          class="w-full rounded-xl bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500 transition resize-none"></textarea>
      </div>

      <div>
        <p class="text-xs font-medium text-neutral-700 dark:text-neutral-300 mb-2">Presets</p>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-preset="full-admin" class="edit-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Full Admin</button>
          <button type="button" data-preset="read-only" class="edit-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Read-Only</button>
          <button type="button" data-preset="server-manager" class="edit-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Server Manager</button>
          <button type="button" data-preset="user-manager" class="edit-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">User Manager</button>
          <button type="button" data-preset="node-monitor" class="edit-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Node Monitor</button>
          <button type="button" data-preset="none" class="edit-preset-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 transition-all duration-150 active:scale-95">Clear All</button>
        </div>
      </div>

      <div>
        <p class="text-xs font-medium text-neutral-700 dark:text-neutral-300 mb-2">Permissions</p>
        <div class="space-y-2">
          <% ['servers', 'users', 'nodes', 'settings'].forEach(category => { %>
            <div class="rounded-xl border border-neutral-200 dark:border-neutral-700/60 overflow-hidden">
              <button type="button"
                class="w-full flex items-center justify-between px-4 py-3 bg-neutral-50 dark:bg-neutral-800 active:bg-neutral-100 dark:active:bg-neutral-700/60 transition-colors"
                aria-expanded="false"
                onclick="toggleCat(this)">
                <div class="flex items-center gap-2">
                  <span class="text-xs font-medium text-neutral-700 dark:text-neutral-300 capitalize"><%= category %></span>
                  <span class="edit-cat-count text-[10px] text-neutral-400 dark:text-neutral-500" data-category="<%= category %>"></span>
                </div>
                <svg class="category-chevron w-3.5 h-3.5 text-neutral-400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </button>
              <div class="category-panel hidden px-3 py-3 bg-white dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-700/60">
                <div class="grid grid-cols-2 gap-2">
                  <% allPermissions.filter(p => p.value.includes(category)).forEach(permission => { %>
                    <label class="edit-perm-label flex items-center gap-2 px-3 py-2.5 rounded-lg border border-neutral-100 dark:border-neutral-700/40 bg-neutral-50 dark:bg-neutral-800/50 cursor-pointer active:scale-95 transition-all duration-150">
                      <input type="checkbox" name="permissions" value="<%= permission.value %>"
                        id="edit-permission-<%= permission.value %>"
                        class="edit-permission-checkbox h-3.5 w-3.5 rounded shrink-0" data-category="<%= category %>"
                        onchange="refreshLabels(this, 'edit', '<%= category %>')">
                      <svg class="check-icon w-3.5 h-3.5 text-white opacity-0 shrink-0 transition-opacity duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                      </svg>
                      <span class="perm-text text-xs text-neutral-600 dark:text-neutral-300"><%= permission.name.split(' - ')[1] || permission.name %></span>
                    </label>
                  <% }); %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="flex gap-2 pb-2">
        <button type="button" onclick="hideEditModal()" class="flex-1 py-2.5 text-xs font-medium rounded-xl border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 active:scale-95 transition"><%= req.translations.cancel || 'Cancel' %></button>
        <button type="submit" class="flex-1 py-2.5 text-xs font-medium rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 active:scale-95 transition">Update</button>
      </div>
    </form>
  </div>
</div>

<script nonce="<%- nonce %>">
  let activeModalId = null;
  let modalReturnFocus = null;

  function getFocusableElements(root) {
    return Array.from(root.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'))
      .filter(el => !el.disabled && el.offsetParent !== null);
  }

  function copyToClipboard(text) {
    navigator.clipboard.writeText(text)
      .then(() => showToast('API key copied', 'success'))
      .catch(() => showToast('Failed to copy', 'error'));
  }

  function showModal(id) {
    const el = document.getElementById(id);
    const panel = el.querySelector('[role="dialog"]');
    modalReturnFocus = document.activeElement;
    activeModalId = id;
    el.setAttribute('aria-hidden', 'false');
    el.classList.remove('hidden');
    el.classList.add('flex');
    const focusable = getFocusableElements(panel);
    (focusable[0] || panel).focus();
  }

  function hideModal(id) {
    const el = document.getElementById(id);
    el.setAttribute('aria-hidden', 'true');
    el.classList.add('hidden');
    el.classList.remove('flex');
    if (modalReturnFocus && typeof modalReturnFocus.focus === 'function') modalReturnFocus.focus();
    modalReturnFocus = null;
    activeModalId = null;
  }

  document.getElementById('createApiKeyBtn').addEventListener('click', () => showModal('createApiKeyModal'));
  function hideCreateModal() { hideModal('createApiKeyModal'); }
  function hideEditModal() { hideModal('editApiKeyModal'); }

  ['createApiKeyModal', 'editApiKeyModal'].forEach(id => {
    document.getElementById(id).addEventListener('click', function(e) {
      if (e.target === this) hideModal(id);
    });
  });

  document.addEventListener('keydown', function(e) {
    if (!activeModalId) return;
    const modal = document.getElementById(activeModalId);
    const panel = modal.querySelector('[role="dialog"]');
    if (e.key === 'Escape') {
      e.preventDefault();
      hideModal(activeModalId);
      return;
    }
    if (e.key !== 'Tab') return;
    const focusable = getFocusableElements(panel);
    if (!focusable.length) {
      e.preventDefault();
      panel.focus();
      return;
    }
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });

  function toggleCat(btn) {
    const panel = btn.nextElementSibling;
    const expanded = panel.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
    btn.querySelector('.category-chevron').classList.toggle('rotate-180', expanded);
  }

  function refreshLabels(changedCb, form, category) {
    const modal = document.getElementById(form === 'create' ? 'createApiKeyModal' : 'editApiKeyModal');
    const cbSelector = form === 'create' ? '.permission-checkbox' : '.edit-permission-checkbox';
    const labelSelector = form === 'create' ? '.create-perm-label' : '.edit-perm-label';
    const countSelector = form === 'create' ? '.create-cat-count' : '.edit-cat-count';

    const all = modal.querySelectorAll(`${cbSelector}[data-category="${category}"]`);
    const checked = modal.querySelectorAll(`${cbSelector}[data-category="${category}"]:checked`);
    const countEl = modal.querySelector(`${countSelector}[data-category="${category}"]`);
    if (countEl) countEl.textContent = checked.length === 0 ? '' : `${checked.length}/${all.length}`;

    all.forEach(cb => {
      const label = cb.closest(labelSelector);
      const text = label.querySelector('.perm-text');
      if (cb.checked) {
        label.classList.add('border-neutral-900', 'bg-neutral-900');
        label.classList.remove('border-neutral-100', 'dark:border-neutral-700/40', 'bg-neutral-50', 'dark:bg-neutral-800/50');
        text.classList.add('text-white');
        text.classList.remove('text-neutral-600', 'dark:text-neutral-300');
      } else {
        label.classList.remove('border-neutral-900', 'bg-neutral-900');
        label.classList.add('border-neutral-100', 'dark:border-neutral-700/40', 'bg-neutral-50', 'dark:bg-neutral-800/50');
        text.classList.remove('text-white');
        text.classList.add('text-neutral-600', 'dark:text-neutral-300');
      }
    });
  }

  const presetPermissions = {
    'full-admin': [
      'airlink.api.servers.read','airlink.api.servers.create','airlink.api.servers.update','airlink.api.servers.delete',
      'airlink.api.users.read','airlink.api.users.create','airlink.api.users.update','airlink.api.users.delete',
      'airlink.api.nodes.read','airlink.api.nodes.create','airlink.api.nodes.update','airlink.api.nodes.delete',
      'airlink.api.settings.read','airlink.api.settings.update'
    ],
    'read-only': ['airlink.api.servers.read','airlink.api.users.read','airlink.api.nodes.read','airlink.api.settings.read'],
    'server-manager': ['airlink.api.servers.read','airlink.api.servers.create','airlink.api.servers.update','airlink.api.servers.delete','airlink.api.nodes.read'],
    'user-manager': ['airlink.api.users.read','airlink.api.users.create','airlink.api.users.update','airlink.api.users.delete','airlink.api.servers.read'],
    'node-monitor': ['airlink.api.nodes.read','airlink.api.servers.read'],
    'none': []
  };

  function applyPreset(preset, form) {
    const allowed = presetPermissions[preset] || [];
    const modal = document.getElementById(form === 'create' ? 'createApiKeyModal' : 'editApiKeyModal');
    const cbSelector = form === 'create' ? '.permission-checkbox' : '.edit-permission-checkbox';
    const btnSelector = form === 'create' ? '.create-preset-btn' : '.edit-preset-btn';

    modal.querySelectorAll(cbSelector).forEach(cb => { cb.checked = allowed.includes(cb.value); });
    ['servers','users','nodes','settings'].forEach(cat => refreshLabels(null, form, cat));

    modal.querySelectorAll(btnSelector).forEach(b => {
      b.classList.remove('bg-neutral-900','text-white','border-neutral-900');
      b.classList.add('bg-white','dark:bg-neutral-800','text-neutral-700','dark:text-neutral-300','border-neutral-200','dark:border-neutral-700');
    });
    const active = modal.querySelector(`${btnSelector}[data-preset="${preset}"]`);
    if (active) {
      active.classList.remove('bg-white','dark:bg-neutral-800','text-neutral-700','dark:text-neutral-300','border-neutral-200','dark:border-neutral-700');
      active.classList.add('bg-neutral-900','text-white','border-neutral-900');
    }
  }

  document.querySelectorAll('.create-preset-btn').forEach(b => b.addEventListener('click', () => applyPreset(b.dataset.preset, 'create')));
  document.querySelectorAll('.edit-preset-btn').forEach(b => b.addEventListener('click', () => applyPreset(b.dataset.preset, 'edit')));

  function showEditModal(id, name, description, permissions) {
    document.getElementById('editApiKeyForm').action = `/admin/apikeys/edit/${id}`;
    document.getElementById('edit-name').value = name;
    document.getElementById('edit-description').value = description;
    document.querySelectorAll('.edit-permission-checkbox').forEach(cb => { cb.checked = false; });
    try {
      const perms = typeof permissions === 'string' ? JSON.parse(permissions) : permissions;
      perms.forEach(p => { const cb = document.getElementById(`edit-permission-${p}`); if (cb) cb.checked = true; });
    } catch {}
    ['servers','users','nodes','settings'].forEach(cat => refreshLabels(null, 'edit', cat));
    showModal('editApiKeyModal');
  }
</script>

<%- include('../../components/footer') %>

<script nonce="<%- nonce %>">
  function showConfirmModal(title, message, onConfirm) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black/60 z-50 flex items-end justify-center';
    modal.innerHTML = `
      <div class="bg-white dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-700/60 rounded-t-2xl p-5 w-full shadow-2xl">
        <h2 class="text-sm font-semibold text-neutral-800 dark:text-white mb-1">${title}</h2>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 mb-5">${message}</p>
        <div class="flex gap-2">
          <button id="modalCancel" class="flex-1 py-2.5 text-sm font-medium rounded-xl bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 active:scale-95 transition">Cancel</button>
          <button id="modalConfirm" class="flex-1 py-2.5 text-sm font-medium rounded-xl bg-red-600 text-white active:scale-95 transition">Delete</button>
        </div>
      </div>`;
    document.body.appendChild(modal);
    const close = () => { document.body.removeChild(modal); };
    modal.querySelector('#modalCancel').addEventListener('click', close);
    modal.querySelector('#modalConfirm').addEventListener('click', () => { close(); onConfirm(); });
  }

  function confirmDeleteApiKey(keyId) {
    if (window.modal && typeof window.modal.confirm === 'function') {
      window.modal.confirm({
        title: 'Delete API key',
        body: 'This will permanently revoke the key. Any integrations using it will stop working.',
        danger: true,
        confirmLabel: 'Delete',
        onConfirm: () => {
          document.getElementById('deleteKeyForm_' + keyId).submit();
        }
      });
      return;
    }
    showConfirmModal('Delete API key', 'This will permanently revoke the key. Any integrations using it will stop working.', () => {
      document.getElementById('deleteKeyForm_' + keyId).submit();
    });
  }

  (function staggerCards() {
    var cards = document.querySelectorAll('.space-y-2 > div');
    cards.forEach(function(card, i) {
      card.style.opacity = '0';
      card.style.transform = 'translateY(6px)';
      card.style.transition = 'none';
      setTimeout(function() {
        card.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
        setTimeout(function() { card.style.transition = ''; card.style.opacity = ''; card.style.transform = ''; }, 220);
      }, i * 40);
    });
  })();
</script>
