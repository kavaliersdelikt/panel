<%- include('../../components/header', { title: 'Admin' }) %>

<main class="">
  <%- include('../../components/template') %>

  <div class="px-4 py-5">
    <div class="mb-5">
      <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.adminMenuTitle || 'Admin Panel' %></h1>
      <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.adminMenuSubtitle || 'Manage your panel' %></p>
    </div>

    <div class="space-y-2">

      <a href="/admin/overview" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <%- icon('grid', { size: 18, class: 'text-neutral-600 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navOverview || 'Overview' %></p>
          <p class="text-xs text-neutral-500 truncate"><%= req.translations.adminMenuOverviewDesc || 'Panel stats and activity' %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>

      <a href="/admin/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <%- icon('settings', { size: 18, class: 'text-neutral-600 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navSettings || 'Settings' %></p>
          <p class="text-xs text-neutral-500 truncate"><%= req.translations.adminMenuSettingsDesc || 'Panel configuration' %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>

      <a href="/admin/servers" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <%- icon('server', { size: 18, class: 'text-neutral-600 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navServers || 'Servers' %></p>
          <p class="text-xs text-neutral-500 truncate"><%= req.translations.adminMenuServersDesc || 'Manage all servers' %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>

      <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <%- icon('users', { size: 18, class: 'text-neutral-600 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navUsers || 'Users' %></p>
          <p class="text-xs text-neutral-500 truncate"><%= req.translations.adminMenuUsersDesc || 'Manage accounts' %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>

      <a href="/admin/nodes" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-neutral-600 dark:text-neutral-300">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navNodes || 'Nodes' %></p>
          <p class="text-xs text-neutral-500 truncate"><%= req.translations.adminMenuNodesDesc || 'Daemon nodes' %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>

      <a href="/admin/images" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <%- icon('image', { size: 18, class: 'text-neutral-600 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navImages || 'Images' %></p>
          <p class="text-xs text-neutral-500 truncate"><%= req.translations.adminMenuImagesDesc || 'Docker images' %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>

      <a href="/admin/addons" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <%- icon('box', { size: 18, class: 'text-neutral-600 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navAddons || 'Addons' %></p>
          <p class="text-xs text-neutral-500 truncate"><%= req.translations.adminMenuAddonsDesc || 'Extensions and plugins' %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>

      <a href="/admin/airlink-cloud" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <%- icon('cloud', { size: 18, class: 'text-neutral-600 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
           <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navAirlinkCloud || 'Airlink Cloud' %></p>
           <p class="text-xs text-neutral-500 truncate">Cloud storage integration</p>
         </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>

      <a href="/admin/apikeys" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <%- icon('key', { size: 18, class: 'text-neutral-600 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navApiKeys || 'API Keys' %></p>
          <p class="text-xs text-neutral-500 truncate"><%= req.translations.adminMenuApiKeysDesc || 'Access tokens' %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>

      <% if (adminMenuItems && adminMenuItems.length > 0) {
        adminMenuItems.forEach(item => { %>
      <a href="<%= item.url %>" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0 overflow-hidden">
          <div class="w-5 h-5 flex items-center justify-center [&>svg]:w-5 [&>svg]:h-5 [&>svg]:shrink-0">
            <%- item.icon %>
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= item.label %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>
      <% }); } %>

    </div>
  </div>
</main>

<%- include('../../components/footer') %>
